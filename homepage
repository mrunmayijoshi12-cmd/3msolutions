<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width,initial-scale=1"/>
<title>3M Solutions – Customized Solutions for Water Treatment</title>
<style>
*{margin:0;padding:0;box-sizing:border-box}
:root{
  --navy:#0a2e5c;--blue:#1156a0;--sky:#4db8ff;--red:#e63946;
  --green:#1d9e75;--amber:#ef9f27;--gray:#5a7a9a;--light:#f5f9ff;
  --white:#fff;--border:#d6e8f7;
}
html{scroll-behavior:smooth}
body{font-family:'Segoe UI',Arial,sans-serif;color:#1a2e44;background:#fff;overflow-x:hidden}
a{text-decoration:none;color:inherit}

/* ANIMATIONS */
@keyframes fadeUp{from{opacity:0;transform:translateY(24px)}to{opacity:1;transform:translateY(0)}}
@keyframes fadeIn{from{opacity:0}to{opacity:1}}
@keyframes slideRight{from{opacity:0;transform:translateX(-24px)}to{opacity:1;transform:translateX(0)}}
@keyframes pulse{0%,100%{transform:scale(1)}50%{transform:scale(1.04)}}
.anim-up{animation:fadeUp .6s ease both}
.anim-up-2{animation:fadeUp .6s .15s ease both}
.anim-up-3{animation:fadeUp .6s .3s ease both}
.anim-fade{animation:fadeIn .7s ease both}

/* NAV */
nav{background:var(--navy);padding:0 5%;display:flex;align-items:center;justify-content:space-between;height:68px;position:sticky;top:0;z-index:200;box-shadow:0 2px 16px rgba(0,0,0,.22)}
.nav-logo{display:flex;align-items:center;gap:10px}
.brand{display:flex;flex-direction:column;line-height:1}
.brand-top{color:#fff;font-size:17px;font-weight:700;letter-spacing:.5px}
.brand-bot{color:var(--sky);font-size:9px;font-weight:700;letter-spacing:2.5px;text-transform:uppercase;margin-top:2px}
.nav-links{display:flex;gap:20px;align-items:center}
.nav-links a{color:#cce6ff;font-size:13px;font-weight:500;transition:color .2s;position:relative;padding-bottom:2px}
.nav-links a::after{content:'';position:absolute;bottom:0;left:0;width:0;height:1.5px;background:var(--sky);transition:width .25s}
.nav-links a:hover{color:#fff}
.nav-links a:hover::after{width:100%}
.nav-cta{background:var(--red)!important;color:#fff!important;padding:9px 18px;border-radius:6px;font-weight:700!important;font-size:12px!important;transition:background .2s!important;border:none!important}
.nav-cta::after{display:none!important}
.nav-cta:hover{background:#c72d3a!important}

/* HERO */
.hero{background:linear-gradient(135deg,#061e3e 0%,#0a2e5c 40%,#1156a0 75%,#1a78c2 100%);padding:80px 5% 72px;display:flex;align-items:center;gap:52px;min-height:500px;position:relative;overflow:hidden}
.hero::before{content:'';position:absolute;top:-80px;right:-80px;width:420px;height:420px;border-radius:50%;background:radial-gradient(circle,rgba(77,184,255,.12) 0%,transparent 70%);pointer-events:none}
.hero::after{content:'';position:absolute;bottom:-60px;left:20%;width:300px;height:300px;border-radius:50%;background:radial-gradient(circle,rgba(230,57,70,.08) 0%,transparent 70%);pointer-events:none}
.hero-text{flex:1;position:relative;z-index:1}
.hero-badge{display:inline-flex;align-items:center;gap:6px;background:rgba(230,57,70,.18);color:#ff8a93;border:1px solid rgba(230,57,70,.35);border-radius:20px;padding:5px 14px;font-size:12px;font-weight:600;letter-spacing:.4px;margin-bottom:20px}
.hero-badge::before{content:'';width:7px;height:7px;border-radius:50%;background:#ff8a93;animation:pulse 2s infinite}
.hero h1{color:#fff;font-size:40px;font-weight:700;line-height:1.2;margin-bottom:14px}
.hero h1 span{color:var(--sky)}
.hero-tagline{color:var(--red);font-size:14px;font-weight:600;font-style:italic;margin-bottom:14px;letter-spacing:.3px}
.hero p{color:#a8ccee;font-size:15px;line-height:1.8;max-width:500px;margin-bottom:14px}
.hero-compare{display:flex;align-items:center;gap:7px;margin-bottom:30px;flex-wrap:wrap}
.hero-compare span{font-size:12px;color:#7fa8cc}
.comp-badge{background:rgba(77,184,255,.15);color:#7ed4ff;border:1px solid rgba(77,184,255,.3);border-radius:4px;padding:3px 10px;font-size:11px;font-weight:700;transition:background .2s}
.comp-badge:hover{background:rgba(77,184,255,.28)}
.hero-btns{display:flex;gap:12px;flex-wrap:wrap}
.btn-primary{background:var(--red);color:#fff;padding:13px 28px;border-radius:8px;font-weight:700;font-size:14px;border:none;cursor:pointer;display:inline-block;transition:all .2s;box-shadow:0 4px 14px rgba(230,57,70,.3)}
.btn-primary:hover{background:#c72d3a;transform:translateY(-1px);box-shadow:0 6px 18px rgba(230,57,70,.4)}
.btn-outline{background:transparent;color:#fff;padding:12px 26px;border-radius:8px;font-weight:600;font-size:14px;border:2px solid rgba(255,255,255,.35);cursor:pointer;display:inline-block;transition:all .2s}
.btn-outline:hover{border-color:#fff;background:rgba(255,255,255,.1)}
.hero-visual{flex:0 0 285px;display:flex;flex-direction:column;gap:10px;position:relative;z-index:1}
.stat-card{background:rgba(255,255,255,.09);border:1px solid rgba(255,255,255,.14);border-radius:12px;padding:14px 18px;transition:transform .2s,background .2s;cursor:default}
.stat-card:hover{background:rgba(255,255,255,.14);transform:translateX(4px)}
.stat-card .num{color:var(--sky);font-size:24px;font-weight:700}
.stat-card .lbl{color:#a8ccee;font-size:12px;margin-top:2px}

/* STATS BAR */
.stats-bar{background:var(--light);border-top:3px solid var(--red);padding:22px 5%;display:flex;justify-content:space-around;text-align:center;flex-wrap:wrap;gap:16px}
.stat-item{cursor:default;transition:transform .2s}
.stat-item:hover{transform:translateY(-2px)}
.stat-item .n{font-size:20px;font-weight:700;color:var(--navy)}
.stat-item .t{font-size:12px;color:var(--gray);margin-top:3px}

/* MFG BANNER */
.mfg-banner{background:linear-gradient(135deg,var(--navy),var(--blue));padding:32px 5%;display:flex;align-items:center;justify-content:space-between;gap:24px;flex-wrap:wrap}
.mfg-banner .left h2{color:#fff;font-size:20px;font-weight:700;margin-bottom:7px}
.mfg-banner .left p{color:#a8ccee;font-size:13px;line-height:1.65;max-width:580px}
.mfg-banner .right{display:flex;gap:10px;flex-wrap:wrap}
.comp-pill{background:rgba(255,255,255,.12);border:1px solid rgba(255,255,255,.2);color:#fff;font-size:12px;font-weight:600;padding:7px 14px;border-radius:20px;transition:background .2s}
.comp-pill:hover{background:rgba(255,255,255,.2)}

/* SECTIONS */
section{padding:64px 5%}
.section-label{font-size:11px;font-weight:700;color:var(--red);letter-spacing:2px;text-transform:uppercase;margin-bottom:10px}
.section-title{font-size:28px;font-weight:700;color:var(--navy);margin-bottom:10px;line-height:1.25}
.section-sub{font-size:14px;color:var(--gray);max-width:600px;line-height:1.75;margin-bottom:40px}

/* AREAS */
.areas{background:#fff}
.areas-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(210px,1fr));gap:18px}
.area-card{border:1.5px solid var(--border);border-radius:14px;padding:24px 20px;transition:box-shadow .25s,transform .25s,border-color .25s;cursor:default}
.area-card:hover{box-shadow:0 10px 32px rgba(10,46,92,.12);transform:translateY(-4px);border-color:var(--sky)}
.area-card::before{content:'';display:block;height:3px;border-radius:2px;margin-bottom:18px}
.area-ro::before{background:linear-gradient(90deg,var(--navy),var(--sky))}
.area-boiler::before{background:linear-gradient(90deg,#7c0000,var(--red))}
.area-cooling::before{background:linear-gradient(90deg,#085041,var(--green))}
.area-chilling::before{background:linear-gradient(90deg,#042c53,#378add)}
.area-etp::before{background:linear-gradient(90deg,#412402,var(--amber))}
.area-plants::before{background:linear-gradient(90deg,#26215c,#7f77dd)}
.area-icon{font-size:26px;margin-bottom:12px}
.area-card h3{font-size:15px;font-weight:700;color:var(--navy);margin-bottom:8px}
.area-card p{font-size:13px;color:var(--gray);line-height:1.6;margin-bottom:14px}
.area-tags{display:flex;flex-wrap:wrap;gap:5px}
.atag{font-size:11px;font-weight:600;padding:3px 9px;border-radius:20px;background:#f0f6ff;color:#1156a0}
.atag-red{background:#fff0f1;color:#c72d3a}
.atag-green{background:#e8f7f0;color:#0f6e56}
.atag-amber{background:#fff8ec;color:#854f0b}
.atag-purple{background:#eeedfe;color:#3c3489}

/* PRODUCTS TABS */
.products{background:var(--light)}
.tab-bar{display:flex;gap:8px;flex-wrap:wrap;margin-bottom:32px}
.tab-btn{padding:9px 18px;border-radius:20px;border:1.5px solid var(--border);background:#fff;font-size:13px;font-weight:600;color:var(--gray);cursor:pointer;transition:all .2s}
.tab-btn:hover{border-color:var(--sky);color:var(--navy)}
.tab-btn.active{background:var(--navy);color:#fff;border-color:var(--navy)}
.tab-panel{display:none}
.tab-panel.active{display:grid;grid-template-columns:repeat(auto-fit,minmax(250px,1fr));gap:18px;animation:fadeUp .4s ease}
.product-card{background:#fff;border:1.5px solid var(--border);border-radius:14px;overflow:hidden;transition:box-shadow .25s,transform .25s,border-color .25s}
.product-card:hover{box-shadow:0 10px 30px rgba(10,46,92,.1);transform:translateY(-3px);border-color:var(--sky)}
.prod-header{height:10px}
.prod-header-blue{background:linear-gradient(90deg,var(--navy),var(--sky))}
.prod-header-red{background:linear-gradient(90deg,#7c0000,var(--red))}
.prod-header-green{background:linear-gradient(90deg,#085041,var(--green))}
.prod-header-amber{background:linear-gradient(90deg,#412402,var(--amber))}
.prod-body{padding:20px 22px}
.prod-code{font-size:11px;font-weight:700;color:var(--sky);letter-spacing:1px;margin-bottom:5px}
.prod-body h3{font-size:16px;font-weight:700;color:var(--navy);margin-bottom:8px}
.prod-body p{font-size:13px;color:var(--gray);line-height:1.65;margin-bottom:14px}
.feat-list{list-style:none;margin-bottom:14px}
.feat-list li{font-size:12px;color:#1a2e44;padding:3px 0;display:flex;gap:7px;align-items:flex-start}
.feat-list li::before{content:'✓';color:var(--green);font-weight:700;font-size:12px;flex-shrink:0;margin-top:1px}
.tag-list{display:flex;flex-wrap:wrap;gap:5px;margin-bottom:14px}
.tag{background:#f0f6ff;color:#1156a0;font-size:11px;font-weight:600;padding:3px 9px;border-radius:20px}
.prod-more{display:inline-block;font-size:12px;font-weight:600;color:var(--red);border:1px solid #f5b3b8;border-radius:6px;padding:5px 12px;transition:all .2s}
.prod-more:hover{background:#fff0f1;transform:translateX(2px)}

/* PLANTS */
.plants{background:#fff}
.plants-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(280px,1fr));gap:22px}
.plant-card{border:1.5px solid var(--border);border-radius:14px;overflow:hidden;transition:box-shadow .25s,transform .25s}
.plant-card:hover{box-shadow:0 8px 28px rgba(10,46,92,.1);transform:translateY(-3px)}
.plant-img-placeholder{height:130px;display:flex;align-items:center;justify-content:center;position:relative;overflow:hidden}
.plant-ro{background:linear-gradient(135deg,#e0f0ff,#b8d8f5)}
.plant-dm{background:linear-gradient(135deg,#e8f5e9,#b8dcbd)}
.plant-sc{background:linear-gradient(135deg,#f0f4e8,#d4dfc2)}
.plant-soft{background:linear-gradient(135deg,#e8f0ff,#c0cfee)}
.plant-etp{background:linear-gradient(135deg,#fff3e0,#f5d5a0)}
.plant-img-icon{font-size:44px;opacity:.6}
.plant-img-label{position:absolute;bottom:8px;right:10px;font-size:10px;font-weight:700;color:var(--navy);background:rgba(255,255,255,.75);padding:2px 8px;border-radius:10px;letter-spacing:.5px}
.plant-body{padding:18px 20px}
.plant-body h3{font-size:15px;font-weight:700;color:var(--navy);margin-bottom:7px}
.plant-body p{font-size:13px;color:var(--gray);line-height:1.65;margin-bottom:12px}
.plant-specs{display:flex;gap:10px;flex-wrap:wrap}
.spec{background:var(--light);border:1px solid var(--border);border-radius:6px;padding:4px 10px;font-size:11px;font-weight:600;color:var(--navy)}

/* COMPARE */
.compare{background:var(--light)}
.compare-wrap{overflow-x:auto;border-radius:12px;border:1px solid var(--border)}
.compare-table{width:100%;border-collapse:collapse;background:#fff;min-width:520px}
.compare-table th{background:var(--navy);color:#fff;padding:13px 16px;font-size:13px;font-weight:600;text-align:left}
.compare-table td{padding:12px 16px;font-size:13px;border-bottom:1px solid #eef4fb;color:#1a2e44;transition:background .15s}
.compare-table tr:last-child td{border-bottom:none}
.compare-table tr:hover td{background:#f8fcff}
.compare-table tr:nth-child(even) td{background:#f9fcff}
.compare-table tr:nth-child(even):hover td{background:#f0f8ff}
.hl{background:#e8f7f0!important;color:#0f6e56;font-weight:700}
.chk{color:var(--green);font-weight:700}
.crs{color:var(--red)}

/* CLIENTS */
.clients{background:#fff}
.clients-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(220px,1fr));gap:14px}
.client-card{background:var(--light);border:1px solid var(--border);border-radius:10px;padding:14px 16px;display:flex;align-items:center;gap:12px;transition:box-shadow .2s,transform .2s}
.client-card:hover{box-shadow:0 4px 16px rgba(10,46,92,.09);transform:translateY(-2px)}
.client-num{width:32px;height:32px;min-width:32px;border-radius:8px;background:linear-gradient(135deg,var(--navy),var(--blue));color:#fff;font-size:12px;font-weight:700;display:flex;align-items:center;justify-content:center}
.client-name{font-size:13px;font-weight:600;color:var(--navy);line-height:1.4}
.client-loc{font-size:11px;color:var(--gray);margin-top:2px}

/* LEARN */
.learn{background:var(--light)}
.learn-grid{display:grid;grid-template-columns:1fr 1fr;gap:40px;align-items:center}
.learn-steps{display:flex;flex-direction:column;gap:16px}
.step{display:flex;gap:14px;align-items:flex-start;padding:14px;border-radius:10px;transition:background .2s}
.step:hover{background:#fff}
.step-num{width:34px;height:34px;min-width:34px;border-radius:50%;background:var(--navy);color:#fff;font-size:13px;font-weight:700;display:flex;align-items:center;justify-content:center;flex-shrink:0}
.step-content h4{font-size:14px;font-weight:700;color:var(--navy);margin-bottom:3px}
.step-content p{font-size:13px;color:var(--gray);line-height:1.6}
.learn-visual{background:linear-gradient(135deg,#e0eeff,#c8ddf5);border-radius:16px;padding:30px;text-align:center}
.learn-visual .big-text{font-size:46px;font-weight:800;color:var(--navy);line-height:1}
.learn-visual .sub{font-size:12px;color:var(--gray);margin-top:6px;font-style:italic}
.learn-visual .row{display:flex;justify-content:space-around;margin-top:22px}
.learn-visual .item .val{font-size:22px;font-weight:700;color:var(--blue)}
.learn-visual .item .lbl{font-size:11px;color:var(--gray);margin-top:3px}

/* CONTACT */
.contact{background:#fff}
.contact-grid{display:grid;grid-template-columns:1fr 1.4fr;gap:44px;align-items:start}
.contact-info h3{font-size:19px;font-weight:700;color:var(--navy);margin-bottom:10px}
.contact-info > p{font-size:14px;color:var(--gray);line-height:1.7;margin-bottom:22px}
.info-row{display:flex;gap:12px;align-items:flex-start;margin-bottom:14px;padding:12px;border-radius:10px;transition:background .2s}
.info-row:hover{background:var(--light)}
.info-icon{width:36px;height:36px;min-width:36px;background:#e0f0ff;border-radius:8px;display:flex;align-items:center;justify-content:center;font-size:15px}
.info-row .lbl{font-size:10px;color:#8aabbf;font-weight:700;letter-spacing:.5px;margin-bottom:2px}
.info-row .val{font-size:13px;color:#1a2e44;font-weight:500;line-height:1.5}
.offices-grid{display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-top:14px}
.office-box{background:var(--light);border:1px solid var(--border);border-radius:10px;padding:12px 14px}
.office-box .o-title{font-size:10px;font-weight:700;color:var(--red);letter-spacing:.5px;margin-bottom:5px}
.office-box p{font-size:12px;color:#1a2e44;line-height:1.5}
.gst-box{background:var(--light);border:1px solid var(--border);border-radius:10px;padding:12px 16px;margin-top:14px}
.gst-box .gst-title{font-size:10px;font-weight:700;color:#8aabbf;letter-spacing:.5px;margin-bottom:8px}
.gst-row{display:flex;justify-content:space-between;font-size:12px;padding:4px 0;border-bottom:1px solid #eef4fb}
.gst-row:last-child{border-bottom:none}
.gst-row .k{color:var(--gray)}
.gst-row .v{font-weight:600;color:var(--navy);font-family:monospace;font-size:11px}
.contact-form{background:var(--light);border-radius:14px;padding:30px;border:1px solid var(--border)}
.contact-form h3{font-size:17px;font-weight:700;color:var(--navy);margin-bottom:6px}
.contact-form .sub{font-size:13px;color:var(--gray);margin-bottom:20px}
.form-row{display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-bottom:12px}
.field{display:flex;flex-direction:column;gap:5px;margin-bottom:12px}
.field label{font-size:11px;font-weight:700;color:var(--gray);letter-spacing:.3px}
.field input,.field select,.field textarea{padding:10px 13px;border:1.5px solid var(--border);border-radius:8px;font-size:13px;color:#1a2e44;outline:none;font-family:inherit;transition:border-color .2s,box-shadow .2s;background:#fff}
.field input:focus,.field select:focus,.field textarea:focus{border-color:var(--sky);box-shadow:0 0 0 3px rgba(77,184,255,.12)}
.field textarea{resize:vertical;min-height:80px}
.submit-btn{width:100%;background:var(--red);color:#fff;padding:13px;border-radius:8px;font-size:14px;font-weight:700;border:none;cursor:pointer;transition:all .2s;box-shadow:0 4px 12px rgba(230,57,70,.25)}
.submit-btn:hover{background:#c72d3a;transform:translateY(-1px);box-shadow:0 6px 16px rgba(230,57,70,.35)}

/* FOOTER */
footer{background:var(--navy);padding:48px 5% 24px}
.footer-top{display:grid;grid-template-columns:1.6fr 1fr 1fr 1fr;gap:32px;margin-bottom:36px}
.footer-brand-name{color:#fff;font-size:18px;font-weight:800;margin-bottom:2px}
.footer-brand-sub{color:var(--sky);font-size:9px;font-weight:700;letter-spacing:2.5px;text-transform:uppercase;margin-bottom:12px}
.footer-brand p{font-size:13px;line-height:1.75;color:#7fa8cc}
.footer-col h5{color:#fff;font-size:12px;font-weight:700;margin-bottom:14px;letter-spacing:.5px;padding-bottom:8px;border-bottom:1px solid rgba(255,255,255,.1)}
.footer-col ul{list-style:none}
.footer-col li{margin-bottom:8px}
.footer-col li a{font-size:12px;color:#7fa8cc;transition:color .2s;display:flex;align-items:center;gap:5px}
.footer-col li a:hover{color:#fff}
.footer-col li a::before{content:'›';font-size:14px;color:var(--sky)}
.footer-contact-item{font-size:12px;color:#7fa8cc;margin-bottom:9px;line-height:1.5}
.footer-contact-item strong{color:#cce6ff;display:block;font-size:10px;letter-spacing:.3px;margin-bottom:1px}
.footer-bottom{border-top:1px solid rgba(255,255,255,.1);padding-top:20px;display:flex;justify-content:space-between;font-size:11px;color:#5a80a0;flex-wrap:wrap;gap:8px}

/* SCROLL TO TOP */
.scroll-top{position:fixed;bottom:28px;right:28px;width:44px;height:44px;border-radius:50%;background:var(--navy);border:2px solid var(--sky);color:var(--sky);font-size:18px;cursor:pointer;display:flex;align-items:center;justify-content:center;transition:all .25s;z-index:99;opacity:0;pointer-events:none;box-shadow:0 4px 14px rgba(10,46,92,.3)}
.scroll-top.visible{opacity:1;pointer-events:auto}
.scroll-top:hover{background:var(--sky);color:var(--navy);transform:translateY(-3px)}

/* WHATSAPP FLOAT */
.wa-btn{position:fixed;bottom:80px;right:26px;background:#25d366;color:#fff;width:46px;height:46px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:22px;box-shadow:0 4px 16px rgba(37,211,102,.4);transition:all .25s;z-index:99;text-decoration:none}
.wa-btn:hover{transform:translateY(-3px) scale(1.08);box-shadow:0 6px 20px rgba(37,211,102,.5)}

/* SECTION DIVIDERS */
.wave-divider{width:100%;overflow:hidden;line-height:0;background:var(--light)}
.wave-divider svg{display:block;width:100%}

/* HIGHLIGHT NUMBERS */
.highlight-row{display:flex;gap:0;background:linear-gradient(135deg,var(--navy),var(--blue));border-radius:16px;overflow:hidden;margin-bottom:40px}
.hl-item{flex:1;padding:24px 16px;text-align:center;border-right:1px solid rgba(255,255,255,.1);transition:background .2s}
.hl-item:last-child{border-right:none}
.hl-item:hover{background:rgba(255,255,255,.07)}
.hl-num{font-size:28px;font-weight:800;color:var(--sky);line-height:1}
.hl-txt{font-size:12px;color:#a8ccee;margin-top:4px;line-height:1.4}

/* TOOLTIP */
[data-tip]{position:relative;cursor:help}
